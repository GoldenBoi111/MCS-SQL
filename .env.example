# MCS-SQL Configuration
# Copy this file to .env and update paths for your environment

# =============================================================================
# Base Paths
# =============================================================================

# Root directory of the MCS-SQL project
PROJECT_ROOT=/path/to/MCS-SQL

# =============================================================================
# Dataset Paths
# =============================================================================

# Training dataset
TRAIN_DATASET=${PROJECT_ROOT}/train/train/train.json

# Development databases
DEV_DATABASES=${PROJECT_ROOT}/minidev

# =============================================================================
# FAISS Index Paths
# =============================================================================

# FAISS index for standard (unmasked) questions
FAISS_INDEX=${PROJECT_ROOT}/faiss-index

# FAISS index for masked questions
FAISS_INDEX_MASKED=${PROJECT_ROOT}/faiss-index-masked

# =============================================================================
# Model Configuration
# =============================================================================

# Embedding model name (for sentence-transformers)
EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5

# LLM model name (for Qwen/text generation)
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# =============================================================================
# Prompts Path
# =============================================================================

# Directory containing prompt templates
PROMPTS_DIR=${PROJECT_ROOT}/prompts

# =============================================================================
# Processing Configuration
# =============================================================================

# Batch size for embedding generation
EMBEDDING_BATCH_SIZE=1000

# Batch size for FAISS indexing
INDEX_BATCH_SIZE=10000

# Maximum entries to process (for testing, set to empty for unlimited)
MAX_ENTRIES=

# =============================================================================
# LLM Configuration
# =============================================================================

# Device for LLM inference (cuda or cpu)
LLM_DEVICE=cuda

# Maximum new tokens for LLM generation
LLM_MAX_NEW_TOKENS=512

# Temperature for LLM sampling (0.0 for deterministic)
LLM_TEMPERATURE=0.7

# Number of shuffle iterations for table linking
TABLE_LINKING_ITERATIONS=3

# Number of shuffle iterations for column linking
COLUMN_LINKING_ITERATIONS=3

# Number of parallel outputs for majority voting
MAJORITY_VOTE_N=20

# =============================================================================
# FAISS Configuration
# =============================================================================

# FAISS index type (Flat, IVF, HNSW)
FAISS_INDEX_TYPE=HNSW

# =============================================================================
# Database Configuration
# =============================================================================

# Default database for schema linking (relative to DEV_DATABASES)
DEFAULT_DATABASE=california_schools/california_schools.sqlite
